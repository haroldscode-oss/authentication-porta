# =============================================================================
# SELLER SERVICES MARKETPLACE - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control - add it to .gitignore

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL="postgresql://username:password@localhost:5432/seller_services_db"
# Alternative for MongoDB: mongodb://username:password@localhost:27017/seller_services_db
# Alternative for MySQL: mysql://username:password@localhost:3306/seller_services_db

# =============================================================================
# AUTHENTICATION & SESSION
# =============================================================================
# Generate a strong random string for JWT signing (min 32 characters)
JWT_SECRET="your-super-secure-jwt-secret-key-here-make-it-long"
# Session secret for express-session (if using sessions instead of JWT)
SESSION_SECRET="your-session-secret-key-here"
# Token expiration time
JWT_EXPIRES_IN="7d"
# Refresh token expiration
REFRESH_TOKEN_EXPIRES_IN="30d"

# =============================================================================
# GOOGLE OAUTH2 CONFIGURATION
# =============================================================================
# Get these from: https://console.developers.google.com/
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"
# For production, update to your domain:
# GOOGLE_REDIRECT_URI="https://yourdomain.com/auth/google/callback"

# =============================================================================
# DISCORD OAUTH2 CONFIGURATION
# =============================================================================
# Get these from: https://discord.com/developers/applications
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"
DISCORD_REDIRECT_URI="http://localhost:3000/auth/discord/callback"
# For production, update to your domain:
# DISCORD_REDIRECT_URI="https://yourdomain.com/auth/discord/callback"

# =============================================================================
# EMAIL SERVICE (for verification & password reset)
# =============================================================================
# Choose one email provider:

# SMTP Configuration (Generic)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Seller Services <noreply@sellerservices.com>"

# SendGrid (Alternative)
# SENDGRID_API_KEY="your-sendgrid-api-key"
# SENDGRID_FROM_EMAIL="noreply@sellerservices.com"

# Mailgun (Alternative)
# MAILGUN_API_KEY="your-mailgun-api-key"
# MAILGUN_DOMAIN="mg.yourdomain.com"

# =============================================================================
# SMS SERVICE (for phone verification)
# =============================================================================
# Twilio Configuration
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"
TWILIO_VERIFY_SERVICE_SID="your-verify-service-sid"

# Alternative: AWS SNS
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_REGION="us-east-1"

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Environment (development, staging, production)
NODE_ENV="development"
# Server port
PORT="3000"
# Base URL for your application
BASE_URL="http://localhost:3000"
# For production: BASE_URL="https://yourdomain.com"

# Frontend URL (if frontend is separate)
FRONTEND_URL="http://localhost:5173"
# For production: FRONTEND_URL="https://yourdomain.com"

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000"
# For production, add your domain:
# ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# =============================================================================
# FILE UPLOAD & STORAGE
# =============================================================================
# Local storage path
UPLOAD_PATH="./uploads"
# Maximum file size (in bytes) - 10MB default
MAX_FILE_SIZE="10485760"

# AWS S3 Configuration (Optional)
# AWS_S3_BUCKET="your-s3-bucket-name"
# AWS_S3_REGION="us-east-1"
# AWS_S3_ACCESS_KEY="your-s3-access-key"
# AWS_S3_SECRET_KEY="your-s3-secret-key"

# =============================================================================
# RATE LIMITING
# =============================================================================
# Rate limit window in minutes
RATE_LIMIT_WINDOW="15"
# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS="100"
# Auth specific rate limits
AUTH_RATE_LIMIT_WINDOW="15"
AUTH_RATE_LIMIT_MAX_REQUESTS="5"

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# BCRYPT salt rounds (10-12 recommended)
BCRYPT_SALT_ROUNDS="12"
# Password reset token expiration (in minutes)
PASSWORD_RESET_EXPIRES="15"
# Email verification token expiration (in hours)
EMAIL_VERIFICATION_EXPIRES="24"
# SMS verification code expiration (in minutes)
SMS_VERIFICATION_EXPIRES="10"

# =============================================================================
# PAYMENT PROCESSING (Optional - for marketplace features)
# =============================================================================
# Stripe Configuration
# STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
# STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
# STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# PayPal Configuration
# PAYPAL_CLIENT_ID="your-paypal-client-id"
# PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
# PAYPAL_MODE="sandbox"  # or "live" for production

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
# Log level (error, warn, info, debug)
LOG_LEVEL="info"
# Log file path
LOG_FILE="./logs/app.log"

# Sentry (Error tracking)
# SENTRY_DSN="your-sentry-dsn-url"

# =============================================================================
# REDIS CONFIGURATION (Optional - for sessions/caching)
# =============================================================================
# REDIS_URL="redis://localhost:6379"
# REDIS_PASSWORD="your-redis-password"

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================
# Set to true to enable debug logging
DEBUG="false"
# Set to true to enable detailed error responses
DETAILED_ERRORS="true"
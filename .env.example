# =============================================================================
# SELLER SERVICES - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit the .env file to version control

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Replace with your database connection string
DATABASE_URL=postgresql://username:password@localhost:5432/seller_services
# Alternative: SQLite for development
# DATABASE_URL=file:./dev.db

# =============================================================================
# SESSION & SECURITY
# =============================================================================
# Generate a secure random string for session encryption
# Use: openssl rand -base64 32
SESSION_SECRET=your_super_secure_session_secret_here_replace_this

# JWT Token settings
JWT_SECRET=your_jwt_secret_key_here_replace_this
JWT_EXPIRES_IN=7d

# =============================================================================
# DISCORD OAUTH2 CONFIGURATION
# =============================================================================
# Get these from: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# =============================================================================
# GOOGLE OAUTH2 CONFIGURATION
# =============================================================================
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# =============================================================================
# EMAIL SERVICE (for verification codes and password resets)
# =============================================================================
# SMTP Configuration (e.g., Gmail, SendGrid, Mailgun)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Alternative: SendGrid API
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# =============================================================================
# SMS SERVICE (for SMS verification codes)
# =============================================================================
# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Alternative: AWS SNS
# AWS_ACCESS_KEY_ID=your_aws_access_key_here
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
# AWS_REGION=us-east-1

# =============================================================================
# FILE UPLOAD & STORAGE
# =============================================================================
# AWS S3 Configuration (for user avatars, service images, etc.)
AWS_S3_BUCKET_NAME=seller-services-uploads
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY_ID=your_s3_access_key_here
AWS_S3_SECRET_ACCESS_KEY=your_s3_secret_key_here

# =============================================================================
# PAYMENT PROCESSING
# =============================================================================
# Stripe Configuration (for marketplace payments)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# =============================================================================
# REDIS CONFIGURATION (for caching and sessions)
# =============================================================================
REDIS_URL=redis://localhost:6379
# Alternative: Redis Cloud
# REDIS_URL=redis://username:password@hostname:port

# =============================================================================
# RATE LIMITING & SECURITY
# =============================================================================
# Rate limiting settings
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS settings
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
# Sentry for error tracking (optional)
SENTRY_DSN=your_sentry_dsn_here

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Set to true to enable debug mode
DEBUG=true

# Test credentials (remove in production)
TEST_MODE=true